RewriteEngine On

# =========================
# MAINTENANCE MODE (global)
# =========================
ErrorDocument 503 /maintenance.html
ErrorDocument 500 /maintenance.html

# =========================
# Default index
# =========================
DirectoryIndex index.php index.html

<IfModule mod_headers.c>
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  Header set Pragma "no-cache"
  Header set Expires "0"
</IfModule>

# cache static files
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 10 days"
  ExpiresByType image/jpeg "access plus 10 days"
  ExpiresByType image/webp "access plus 10 days"
  ExpiresByType image/svg+xml "access plus 10 days"
  ExpiresByType video/mp4 "access plus 10 days"
</IfModule>

# =========================
# Legacy HTML Overrides
# Force legacy HTML routes to be handled by React Router
# even if the old files still exist on the server.
# =========================
RewriteRule ^main\.html$ /index.php [L]
RewriteRule ^favorites\.html$ /index.php [L]
RewriteRule ^news\.html$ /index.php [L]
RewriteRule ^songs\.html$ /index.php [L]
RewriteRule ^setlists\.html$ /index.php [L]
RewriteRule ^setlist_view\.html$ /index.php [L]
RewriteRule ^setlist_edit\.html$ /index.php [L]
RewriteRule ^song_view\.html$ /index.php [L]
RewriteRule ^song_request\.html$ /index.php [L]
RewriteRule ^account\.html$ /index.php [L]
RewriteRule ^transpose\.html$ /index.php [L]

# =========================
# React Router Fallback
# =========================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php [QSA,L]
